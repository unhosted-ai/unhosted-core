#!/bin/sh
# pre-commit — runs `cargo fmt --check` AND `cargo clippy` so commits
# that fail the Rust CI's lint gates never leave the developer's
# machine. The CI loop where every push triggered a notification
# because of wrap-at-100-vs-80 disagreement (or a clippy lint the
# author didn't run locally) ate hours of inbox attention; this hook
# makes that physically impossible.
#
# Install once:
#   git config core.hooksPath scripts/git-hooks
#
# Bypass for emergencies:
#   git commit --no-verify
#
# Performance: fmt is a few-hundred-ms parse pass. Clippy on an
# incremental build is a few seconds. CLIPPY can be skipped via
# `UNHOSTED_SKIP_CLIPPY=1 git commit` for rapid-fire WIP commits.

set -e

# Only run if we're inside a Cargo workspace. The hook ships in
# every repo that uses scripts/git-hooks; not all are Rust.
if [ ! -f Cargo.toml ]; then
    exit 0
fi

# `cargo fmt --check` exits non-zero if any file would be reformatted.
if ! cargo fmt --all -- --check; then
    echo
    echo "  Rust formatting is out of sync. Run:"
    echo
    echo "    cargo fmt --all"
    echo
    echo "  ...stage the changes, and re-commit."
    echo
    echo "  To bypass this check just this once:"
    echo
    echo "    git commit --no-verify"
    echo
    exit 1
fi

# Clippy — same gate as CI (`-D warnings`). Skipped if the env var
# is set so noisy work-in-progress commits don't pay a 5-10s cost.
if [ -z "${UNHOSTED_SKIP_CLIPPY:-}" ]; then
    if ! cargo clippy --all-targets --all-features -- -D warnings; then
        echo
        echo "  Clippy found warnings/errors. CI runs with -D warnings"
        echo "  and will reject these. Fix locally before pushing."
        echo
        echo "  To skip clippy on a WIP commit (fmt still enforced):"
        echo
        echo "    UNHOSTED_SKIP_CLIPPY=1 git commit ..."
        echo
        exit 1
    fi
fi
