# Claude / agent state — commit shared config (settings.json, hooks/), ignore personal
.claude/settings.local.json
.claude/memory/
.claude/todos/
.claude/scheduled_tasks.lock

# Compiled scripts. Source-of-truth is the .swift file; the
# compiled binary is platform-specific and shouldn't ship in the repo.
scripts/shotter

# macOS
.DS_Store
._*

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log

# OS / common
Thumbs.db
desktop.ini

# Build / dependency artefacts (language TBD — keep this list lean)
node_modules/
dist/
build/
target/
*.app/
*.icns
*.iconset/
__pycache__/
*.pyc
.venv/
venv/

# Tauri auto-generates schema files on every build — never commit.
crates/unhosted-desktop/gen/

# But DO commit the desktop crate's dist/ fallback + icons even though
# `dist/` and `*.icns` are ignored above. These are source assets, not
# build output.
!crates/unhosted-desktop/dist/
!crates/unhosted-desktop/dist/**
!crates/unhosted-desktop/icons/
!crates/unhosted-desktop/icons/**

# Local env
.env
.env.local

# fastembed downloads the embedding model to a cache directory at
# runtime. Default is the working dir on macOS for some reason; we
# explicitly never want those weights checked in.
**/.fastembed_cache/

/target/shotter
